# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # NEVER expose to client
SUPABASE_JWT_SECRET=your-jwt-secret                    # Settings > API > JWT Secret

# === RESEND (email) ===
RESEND_API_KEY=re_your_api_key

# === TWILIO (SMS) ===
TWILIO_ENABLED=false                                   # Set true once account is created
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+12125550000

# === SERVER ===
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173                        # Frontend URL (for CORS + email links)
SALON_TIMEZONE=America/New_York

# === CLIENT (prefix with VITE_) ===
VITE_API_BASE_URL=http://localhost:3001
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# === ADMIN ===
ADMIN_EMAIL=owner@luxethreads.com
